generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String?            // nullable para capturas parciais
  email     String?            // nullable para capturas parciais
  phone     String?            // nullable para capturas parciais
  location  String             // seção do CTA que originou o lead
  status    String   @default("partial")  // partial | complete | checkout

  // Acompanhamento comercial manual do vendedor (pipeline em /admin)
  contacted   Boolean   @default(false)
  contactedAt DateTime? @map("contacted_at")

  // UTMs capturadas do Utmify (cookies) ou da URL
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  utmTerm     String?  @map("utm_term")
  utmContent  String?  @map("utm_content")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Idempotência baseada no fingerprint único (sessionId ou sha256 de email+phone)
  fingerprint String   @unique

  @@map("leads")
}
